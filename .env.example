# Testing and development purposes only
DEBUG=false

# Enables dry-run mode, which only simulates transactions without broadcasting them to the network
DRY_RUN=true

# SP Registry database connection string used for admin operations
SP_REGISTRY_DATABASE_URL=

# Network RPC URL
RPC_URL=

# Private key used in client operations
CLIENT_PRIVATE_KEY=

# Private key used in admin operations
ADMIN_PRIVATE_KEY=

# Private key used in SP operations
SP_PRIVATE_KEY=

# Addresses of smart contract on the given network
POREP_MARKET=
CLIENT_CONTRACT=
SP_REGISTRY=
VALIDATOR_FACTORY=
FILECOIN_PAY=
USDC_TOKEN=
